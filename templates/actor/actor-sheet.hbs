<form class="{{cssClass}}" autocomplete="off">
  
  {{#if needsBuilder}}
    <div class="character-builder-prompt" style="text-align: center; padding: 50px;">
      <h1 style="font-family: 'Playfair Display', serif; color: #e2e8f0; font-size: 32px;">A New Destiny Awaits</h1>
      <p style="color: #a0aec0; margin-bottom: 30px; font-size: 18px;">Before stepping into the madness of the world, you must define who you are.</p>
      <button class="launch-builder" style="background: linear-gradient(135deg, #2c5282, #1a202c); color: white; border: 1px solid #4a5568; padding: 15px 30px; font-size: 20px; cursor: pointer; border-radius: 5px; font-family: 'Crimson Text', serif;">
        <i class="fas fa-magic"></i> Launch Character Builder
      </button>
    </div>
  {{else}}
  
  {{!-- Sheet Header --}}
  <header class="sheet-header">
    <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" />
    
    <div class="header-details">
      <h1 class="charname">
        <input name="name" type="text" value="{{actor.name}}" placeholder="Character Name" />
      </h1>
      
      <div class="header-fields">
        <div class="sequence-box">
          <select name="system.sequence">
            {{#each sequenceOptions}}
              <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
            {{/each}}
          </select>
          <a class="action-roll item-control" title="Roll Action"><i class="fas fa-dice-d20"></i></a>
        </div>
        
        <div class="ancestry-box">
          <label>Ancestry</label>
          <input type="text" name="system.ancestry" value="{{system.ancestry}}" placeholder="None" readonly />
        </div>
        
        <div class="background-box">
          <label>Background</label>
          <input type="text" name="system.background" value="{{system.background}}" placeholder="None" readonly />
        </div>

        <div class="prof-box">
          <label>Prof. Bonus</label>
          <input type="number" name="system.proficiencyBonus" value="{{system.proficiencyBonus}}" min="0" />
        </div>
      </div>
    </div>
  </header>

  {{!-- Sheet Navigation --}}
  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="core">Core</a>
    <a class="item" data-tab="inventory">Inventory</a>
    <a class="item" data-tab="mysticism">Mysticism</a>
  </nav>

  <section class="sheet-body">

  {{!-- Core Tab --}}
  <div class="tab core" data-group="primary" data-tab="core">
    {{!-- Vitals Section --}}
    <section class="vitals-section">
      <div class="vital-bar-container">
        <div class="vital-label hp">HP</div>
        <div class="vital-bar" title="{{system.hp.value}} / {{system.hp.max}}">
          <div class="vital-fill hp-fill" style="width: {{hpPct}}%;"></div>
        </div>
        <div class="vital-inputs">
          <input type="number" name="system.hp.value" value="{{system.hp.value}}" />
          <span>/</span>
          <input type="number" name="system.hp.max" value="{{system.hp.max}}" />
        </div>
      </div>

      <div class="vital-bar-container">
        <div class="vital-label spirit">Spirituality</div>
        <div class="vital-bar" title="{{system.spirituality.value}} / {{system.spirituality.max}}">
          <div class="vital-fill spirit-fill" style="width: {{spiritPct}}%;"></div>
        </div>
        <div class="vital-inputs">
          <input type="number" name="system.spirituality.value" value="{{system.spirituality.value}}" />
          <span>/</span>
          <input type="number" name="system.spirituality.max" value="{{system.spirituality.max}}" />
        </div>
      </div>

      <div class="vital-bar-container">
        <div class="vital-label madness">Madness ({{system.madness}}%)</div>
        <div class="vital-bar" title="{{system.madness}}%">
          <div class="vital-fill madness-fill" style="width: {{system.madness}}%;"></div>
        </div>
        <div class="vital-inputs">
          <input type="number" name="system.madness" value="{{system.madness}}" min="0" max="100" />
        </div>
      </div>
    </section>

    {{!-- Anchor Section --}}
    <section class="anchor-section">
      <h2>Anchor</h2>
      <textarea name="system.anchor" placeholder="Describe the character's anchor to reality...">{{system.anchor}}</textarea>
    </section>

    {{!-- Mutations Section --}}
    <section class="mutations-section">
      <label class="danger-text"><i class="fas fa-disease"></i> Mutations & Corruptions:</label>
      <div class="editor-container corrupted-border">
        {{editor enriched.mutations target="system.mutations" engine="prosemirror" button=true owner=owner editable=editable}}
      </div>
    </section>

    <div class="attributes-skills-container">
      <div class="attributes-list">
        {{#each attributes as |attr key|}}
        <div class="attribute" data-attr="{{key}}">
          <input type="checkbox" name="system.attributes.{{key}}.proficient" {{checked attr.proficient}} title="Proficient" />
          <a class="attr-name attr-label" title="Roll {{attr.label}} Check">{{attr.label}}</a>
          <input type="number" name="system.attributes.{{key}}.value" value="{{attr.value}}" />
          <span class="attr-mod" title="Modifier">{{attr.modStr}}</span>
          <a class="attr-save" title="Roll {{attr.label}} Save"><i class="fas fa-shield-alt"></i></a>
        </div>
        {{/each}}
      </div>
      
      <div class="skills-list">
        {{#each skills as |skill key|}}
        <div class="skill" data-skill="{{key}}">
          <input type="checkbox" name="system.skills.{{key}}.proficient" {{checked skill.proficient}} title="Proficient" />
          <a class="skill-name" title="Roll {{skill.label}}">
            <i class="fas fa-dice-d20"></i> {{skill.label}} <span class="skill-attr">[{{skill.attrLabel}}]</span>
          </a>
          <input type="number" name="system.skills.{{key}}.value" value="{{skill.value}}" title="Skill Value" />
        </div>
        {{/each}}
      </div>
    </div>
  </div> {{!-- End Core Tab --}}

  {{!-- Inventory Tab --}}
  <div class="tab inventory" data-group="primary" data-tab="inventory">
    <section class="items-section">
      {{!-- Encumbrance Bar --}}
      <div class="encumbrance-section">
        <div class="encumbrance-label">Encumbrance ({{encumbrance.value}} / {{encumbrance.max}} lbs)</div>
        <div class="encumbrance-bar">
          <div class="encumbrance-fill" style="width: {{encumbrance.pct}}%;"></div>
        </div>
      </div>
      
      {{!-- Currency Section --}}
      <div class="currency-section">
        <div class="currency-label">Wealth</div>
        <div class="currency-inputs">
          <label>£</label>
          <input type="number" name="system.currency.pounds" value="{{system.currency.pounds}}" title="Pounds" />
          <label>s</label>
          <input type="number" name="system.currency.soli" value="{{system.currency.soli}}" title="Soli" />
          <label>d</label>
          <input type="number" name="system.currency.pence" value="{{system.currency.pence}}" title="Pence" />
        </div>
      </div>
      
      {{!-- Weapons --}}
      <div class="item-list">
        <h3 class="list-header">Weapons</h3>
        {{#each weapons as |item id|}}
        <div class="item" data-item-id="{{item._id}}">
          <div class="item-name">
            <img src="{{item.img}}" title="{{item.name}}" width="32" height="32" />
            <h4>{{item.name}}</h4>
          </div>
          <div class="item-details">
            <span>{{item.system.damage}}</span>
            <span class="item-weight"><i class="fas fa-weight-hanging"></i> {{item.system.weight}} lbs</span>
          </div>
          <div class="item-controls">
            <a class="item-control item-toggle {{#if item.system.equipped}}equipped{{/if}}" title="Toggle Equip">
              <i class="fas fa-shield-alt"></i>
            </a>
            <a class="item-control item-edit" title="Edit Item"><i class="fas fa-edit"></i></a>
            <a class="item-control item-delete" title="Delete Item"><i class="fas fa-trash"></i></a>
          </div>
        </div>
        {{/each}}
        {{#unless weapons.length}}
        <div class="empty-list">No weapons.</div>
        {{/unless}}
      </div>

      {{!-- Armor --}}
      <div class="item-list">
        <h3 class="list-header">Armor</h3>
        {{#each armors as |item id|}}
        <div class="item" data-item-id="{{item._id}}">
          <div class="item-name">
            <img src="{{item.img}}" title="{{item.name}}" width="32" height="32" />
            <h4>{{item.name}}</h4>
          </div>
          <div class="item-details">
            <span>DEF: {{item.system.defense}}</span>
            <span class="item-weight"><i class="fas fa-weight-hanging"></i> {{item.system.weight}} lbs</span>
          </div>
          <div class="item-controls">
            <a class="item-control item-toggle {{#if item.system.equipped}}equipped{{/if}}" title="Toggle Equip">
              <i class="fas fa-tshirt"></i>
            </a>
            <a class="item-control item-edit" title="Edit Item"><i class="fas fa-edit"></i></a>
            <a class="item-control item-delete" title="Delete Item"><i class="fas fa-trash"></i></a>
          </div>
        </div>
        {{/each}}
        {{#unless armors.length}}
        <div class="empty-list">No armor.</div>
        {{/unless}}
      </div>

      {{!-- Gear --}}
      <div class="item-list">
        <h3 class="list-header">Gear</h3>
        {{#each gears as |item id|}}
        <div class="item" data-item-id="{{item._id}}">
          <div class="item-name">
            <img src="{{item.img}}" title="{{item.name}}" width="32" height="32" />
            <h4>{{item.name}}</h4>
          </div>
          <div class="item-details">
            <span>Qty: {{item.system.quantity}}</span>
            <span class="item-weight"><i class="fas fa-weight-hanging"></i> {{item.system.weight}} lbs</span>
          </div>
          <div class="item-controls">
            <a class="item-control item-edit" title="Edit Item"><i class="fas fa-edit"></i></a>
            <a class="item-control item-delete" title="Delete Item"><i class="fas fa-trash"></i></a>
          </div>
        </div>
        {{/each}}
        {{#unless gears.length}}
        <div class="empty-list">No gear.</div>
        {{/unless}}
      </div>
    </section>
  </div> {{!-- End Inventory Tab --}}

  {{!-- Mysticism Tab --}}
  <div class="tab mysticism" data-group="primary" data-tab="mysticism">
    <section class="items-section">
      {{!-- Pathway Powers --}}
      <div class="item-list">
        <h3 class="list-header">Pathway Powers</h3>
        {{#each pathwayPowers as |item id|}}
        <div class="item" data-item-id="{{item._id}}">
          <div class="item-name">
            <img src="{{item.img}}" title="{{item.name}}" width="32" height="32" />
            <h4>{{item.name}}</h4>
          </div>
          <div class="item-details">
            <span>Seq. {{item.system.sequenceRequirement}}</span>
          </div>
          <div class="item-controls">
            <a class="item-control item-edit" title="Edit Item"><i class="fas fa-edit"></i></a>
            <a class="item-control item-delete" title="Delete Item"><i class="fas fa-trash"></i></a>
          </div>
        </div>
        {{/each}}
        {{#unless pathwayPowers.length}}
        <div class="empty-list">No Pathway Powers assigned.</div>
        {{/unless}}
      </div>

      {{!-- Sealed Artifacts --}}
      <div class="item-list">
        <h3 class="list-header">Sealed Artifacts <span class="danger-text"><i class="fas fa-biohazard"></i></span></h3>
        {{#each sealedArtifacts as |item id|}}
        <div class="item" data-item-id="{{item._id}}">
          <div class="item-name">
            <img src="{{item.img}}" title="{{item.name}}" width="32" height="32" />
            <h4 class="danger-text">{{item.name}}</h4>
          </div>
          <div class="item-controls">
            <a class="item-control item-edit" title="Edit Item"><i class="fas fa-edit"></i></a>
            <a class="item-control item-delete" title="Delete Item"><i class="fas fa-trash"></i></a>
          </div>
        </div>
        {{/each}}
        {{#unless sealedArtifacts.length}}
        <div class="empty-list">No Sealed Artifacts.</div>
        {{/unless}}
      </div>

      {{!-- Potion Formulas --}}
      <div class="item-list">
        <h3 class="list-header">Potion Formulas</h3>
        {{#each potionFormulas as |item id|}}
        <div class="item" data-item-id="{{item._id}}">
          <div class="item-name">
            <img src="{{item.img}}" title="{{item.name}}" width="32" height="32" />
            <h4>{{item.name}}</h4>
          </div>
          <div class="item-controls">
            <a class="item-control item-edit" title="Edit Item"><i class="fas fa-edit"></i></a>
            <a class="item-control item-delete" title="Delete Item"><i class="fas fa-trash"></i></a>
          </div>
        </div>
        {{/each}}
        {{#unless potionFormulas.length}}
        <div class="empty-list">No Potion Formulas.</div>
        {{/unless}}
      </div>
    </section>
  </div> {{!-- End Mysticism Tab --}}

  </section> {{!-- End Sheet Body --}}
  {{/if}}
</form>
